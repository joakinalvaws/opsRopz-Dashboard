# Configuración server-side (NO usar prefijo NEXT_PUBLIC: la key nunca debe llegar al navegador).
# En Vercel se configuran como Environment Variables del proyecto.

# URL base del API Gateway (output dashboard_api_url de Terraform), ej:
#   https://abc123.execute-api.us-east-1.amazonaws.com/dev
DASHBOARD_API_URL=

# API key del dashboard (output dashboard_api_key de Terraform, sensible)
DASHBOARD_API_KEY=
